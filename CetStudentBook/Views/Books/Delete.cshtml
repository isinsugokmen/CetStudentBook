@model CetStudentBook.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h2>Delete Book</h2>

<h4>Are you sure you want to delete this?</h4>

<div>
    <strong>Name:</strong> @Model.Name <br />
    <strong>Author:</strong> @Model.Author <br />
    <strong>Publish Date:</strong> @Model.PublishDate.ToShortDateString() <br />
    <strong>Page Count:</strong> @Model.PageCount <br />
    <strong>Second Hand:</strong> @Model.IsSecondHand
</div>

<br />

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>