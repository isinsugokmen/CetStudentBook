@model IEnumerable<CetStudentBook.Models.Book>

<h2>Books</h2>

<p>
    <a asp-action="Create">Create New Book</a>
</p>

<table border="1" cellpadding="5">
    <thead>
    <tr>
        <th>Name</th>
        <th>Author</th>
        <th>Page Count</th>
        <th>Publish Date</th>
        <th>Is Second Hand</th>
        <th>Actions</th>   
    </tr>
    </thead>
    <tbody>
    @foreach (var book in Model)
    {
        <tr>
            <td>@book.Name</td>
            <td>@book.Author</td>
            <td>@book.PageCount</td>
            <td>@book.PublishDate.ToShortDateString()</td>
            <td>@book.IsSecondHand</td>
            <td>
                <a asp-action="Edit" asp-route-id="@book.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@book.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>